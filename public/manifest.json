{
  "manifest_version": 3,
  "name": "Frontend Dev Tool",
  "version": "1.0.1",
  "description": "Inspect computed styles, typography, contrast ratios, and extract page elements.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_icon": {
      "16": "layers.png",
      "48": "layers.png",
      "128": "layers.png"
    }
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "layers.png",
    "48": "layers.png",
    "128": "layers.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/popup.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}