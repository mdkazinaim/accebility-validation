{
  "manifest_version": 3,
  "name": "Accessibility & Design Validator",
  "version": "1.0.0",
  "description": "Inspect computed styles, typography, contrast ratios, and extract page elements.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_icon": "icon.svg"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "css": ["assets/popup.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/popup.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
